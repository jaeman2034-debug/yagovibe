{
  "name": "yago-vibe-spt",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "dev:http": "vite --port 5173",
    "build": "node scripts/generate-sitemap.js && vite build --mode production",
    "build:production": "node scripts/load-env.js && node scripts/generate-sitemap.js && vite build --mode production",
    "build:firebase": "node scripts/generate-sitemap.js && vite build --mode production",
    "build:check": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "npm run build && node scripts/deploy-functions.mjs deploy --only hosting,functions",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:functions": "node scripts/deploy-functions.mjs",
    "emulators:functions": "node scripts/deploy-functions.mjs emulators:start --only functions",
    "emulators": "node scripts/deploy-functions.mjs emulators:start",
    "emulators:start": "node scripts/deploy-functions.mjs emulators:start",
    "deploy:function:annualPrepaid": "node scripts/deploy-functions.mjs deploy --only functions:registerAnnualPrepaidPayment",
    "deploy:functions:repair": "node scripts/deploy-functions-repair.mjs",
    "deploy:rules": "firebase deploy --only firestore:rules,storage",
    "deploy:production": "npm run build && npm run deploy:rules && npm run deploy:functions",
    "generate-env": "tsx scripts/generate-env.ts",
    "export:env": "node scripts/export-env.js",
    "check:env": "node scripts/check-env.cjs",
    "check:build": "node scripts/check-build.cjs",
    "seed:match-test": "node scripts/seed-match-test.js",
    "seed:match-test:production": "node scripts/seed-match-test.js --production",
    "seed:pr9-template": "node scripts/seed-pr9-challenge-template.js",
    "seed:pr9-template:production": "node scripts/seed-pr9-challenge-template.js --production",
    "seed:pr10b-template": "node scripts/seed-pr10b-dribble-template.js",
    "seed:pr10b-template:production": "node scripts/seed-pr10b-dribble-template.js --production",
    "set:admin": "node scripts/set-admin-claim.cjs",
    "migrate:activity:match-ref": "tsx functions/scripts/migrate-activity-match-ref-type.ts",
    "backfill:team-updated-at": "tsx functions/scripts/backfill-team-updated-at.ts",
    "dedupe:team-fees": "tsx functions/scripts/dedupeTeamFeesByMonthKey.ts",
    "merge:trade-chats": "npm --prefix functions run merge:trade-chats --",
    "backfill:team-member-profile-fields": "npm --prefix functions run backfill:team-member-profile-fields --",
    "pre-deploy": "npm run check:env && npm run check:build",
    "pdf-server": "tsx src/server/pdfGenerator.ts",
    "test-pdf": "tsx -e \"import('./src/utils/generateVoiceReportPDF.js').then(m => m.testPDFGeneration())\"",
    "test-signature-pdf": "tsx -e \"import('./src/utils/generateYagoSignatureReport.js').then(m => m.testSignatureReport())\"",
    "dev:nlu": "tsx functions/src/nluServer.ts",
    "test": "jest",
    "test:copilot": "jest tests/test_scenarios.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:copy": "npm run build && npx cap copy",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:assets": "npx capacitor-assets generate",
    "icons:raster": "node scripts/rasterize-pwa-icons.mjs",
    "vision:ops:status": "node scripts/vision-ops-phase2.mjs status",
    "vision:ops:generate": "node scripts/vision-ops-phase2.mjs generate",
    "vision:ops:approve": "node scripts/vision-ops-phase2.mjs approve"
  },
