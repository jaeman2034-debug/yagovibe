{
  "name": "sport-hub-api",
  "version": "1.0.0",
  "description": "축구 허브 API 서버 (Week1~2 Stub)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:seed:grounds": "tsx src/scripts/seed.grounds.ts",
    "db:studio": "prisma studio",
