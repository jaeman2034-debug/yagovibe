# Firebase Functions 완전 전환 패치 환경 변수 설정
# 실제 사용 시 Firebase Console에서 설정하거나 firebase functions:config:set 명령어 사용

# 🔹 Slack 설정 (선택사항)
# Slack Webhook URL (Incoming Webhooks)
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=<SLACK_WEBHOOK_URL>

# 🔹 Firebase Functions 설정 명령어:
firebase functions:config:set slack.webhook="<SLACK_WEBHOOK_URL>"

# 🔹 로컬 테스트용 환경 변수 설정:
# Windows: set SLACK_WEBHOOK_URL=your_webhook_url
# Linux/Mac: export SLACK_WEBHOOK_URL=your_webhook_url

# 🔹 완전 전환 패치 설정
# 이제 vibeReport 함수가 모든 플랫폼을 지원합니다:
# - Slack 슬래시 명령어
# - 웹 API 호출
# - 모바일 앱
# - n8n 자동화
# - Postman 테스트

# 🚀 배포 명령어:
# cd functions
# npm install
# npm run build
# firebase deploy --only functions:vibeReport

# ✅ 테스트 방법:
# 브라우저: https://asia-northeast3-[PROJECT_ID].cloudfunctions.net/vibeReport?period=thisweek
# Slack 명령어에서도 재사용 가능
